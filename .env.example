# ============================================
# Shared Environment — used by both API & Client
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=payment

# ── Application ───────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── Authentication ────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_chars
ADMIN_EMAIL=admin@ashabamusic.com
ADMIN_PASSWORD=change_me_on_first_login

# ── Pesapal Payments ─────────────────────────
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=

# ── Email (SMTP) — optional ──────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ashabamusic.com

# ── AWS S3 — optional, for audio previews ────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ── Client (Vite — VITE_ prefix required) ────
VITE_API_URL=http://localhost:3000
