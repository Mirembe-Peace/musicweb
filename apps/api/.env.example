# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=payment

# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
ADMIN_EMAIL=admin@ashabamusic.com
ADMIN_PASSWORD=change_me_on_first_login

# Pesapal
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_BASE_URL=https://pay.pesapal.com/v3

# Email (SMTP) — optional, emails are skipped if not configured
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ashabamusic.com

# AWS S3 — optional, required for audio preview generation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
