{
  "name": "ashabamusic",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "build:api": "pnpm --filter ashabamusic-api build",
    "build:web": "pnpm --filter ashabamusic-web build",
    "start:api": "pnpm --filter ashabamusic-api start:prod",
    "deploy:firebase": "pnpm build:web && cd apps/client && npx firebase deploy --only hosting"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "bcrypt",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
